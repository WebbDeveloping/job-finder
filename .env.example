# Snippet from vercel:
PRISMA_DATABASE_URL="postgres:****@db.prisma.io:5432/postgres?sslmode=require"
POSTGRES_URL="postgres://****db.prisma.io:5432/postgres?sslmode=require"
PRISMA_DATABASE_URL="postgres://****db.prisma.io:5432/postgres?sslmode=require"