# Prisma Postgres (Vercel Storage → Prisma Postgres → Connect)
# Vercel sets DATABASE_URL (pooled). Add DIRECT_URL from Prisma Console for migrations.
DATABASE_URL="postgres://USER:PASSWORD@pooled.db.prisma.io:5432/postgres?sslmode=require"
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"


# Auth.js (Phase 7+) — generate secret: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Phase 13 — resume file uploads (Vercel Blob)
BLOB_READ_WRITE_TOKEN=

# --- Stripe (Phase 11+) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRO_PRICE_ID=
